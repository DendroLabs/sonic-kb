{
  "CONFIG_DB:BFD_PEER_SINGLE_HOP": {
    "table": "BFD_PEER_SINGLE_HOP",
    "db": "CONFIG_DB",
    "protocols": [
      "bfd"
    ],
    "daemons": [],
    "human_errors": [
      "wrong-reload-order",
      "manual-ip-link",
      "stale-warmboot-files",
      "direct-redis-write",
      "dpkg-force-install",
      "wrong-frr-restart",
      "restart-swss-during-traffic",
      "manual-config-db-json-edit",
      "direct-frr-vtysh"
    ],
    "key_pattern": "BFD_PEER_SINGLE_HOP|<vrfname>|<interface>|<peer-ip>",
    "relevant_fields": [
      "local_addr: source IP address for BFD packets (must match interface IP)",
      "txinterval: desired min TX interval in milliseconds",
      "rxinterval: required min RX interval in milliseconds",
      "multiplier: detection time multiplier (default 3)",
      "multihop: false for single-hop",
      "echo_active: enable echo mode (true/false)",
      "echo_transmit_interval: echo TX interval in milliseconds",
      "shutdown: administratively disable the session (true/false)"
    ],
    "verify_command": "redis-cli -n 4 HGETALL 'BFD_PEER_SINGLE_HOP|default|<ifname>|<peer-ip>'",
    "redis_command": "redis-cli -n 4 KEYS 'BFD_PEER_SINGLE_HOP*'"
  },
